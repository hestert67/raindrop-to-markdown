{
  "name": "raindrop-to-markdown",
  "version": "0.1.0",
  "description": "Import Raindrop.io bookmarks into Obsidian as clean markdown.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "sync-to-vault": "node scripts/sync-to-vault.mjs"
  },
  "keywords": ["obsidian", "plugin", "raindrop", "bookmarks", "markdown"],
  "author": "Thomas Hester",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "turndown": "^7.1.2",
    "@types/turndown": "^5.0.4"
  }
}
